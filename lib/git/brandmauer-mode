#!/usr/bin/env bash
# =============================================================
# brandmauer-mode — set Git repository mode (SAFE, NORMAL, OPEN)
# =============================================================

set -euo pipefail

PREFIX="/usr/local"
SHARE_DIR="$PREFIX/share/brandmauer"
SHAREDLIB_DIR="$SHARE_DIR/shared-lib"
source "$SHAREDLIB_DIR/logging.sh"

SECURITY_ROOT="$HOME/.git-security"
STATE_DIR="$SECURITY_ROOT/state"

# ---------------- ARGUMENT CHECK ----------------
if [[ $# -ne 1 ]]; then
    echo "Usage: $0 <SAFE|NORMAL|OPEN>"
    exit 1
fi

MODE="$1"

case "$MODE" in
    SAFE|NORMAL|OPEN) ;;
    *)
        error " Invalid mode: $MODE"
        exit 1
        ;;
esac

# ---------------- GIT REPOSITORY CHECK ----------------
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    error " Not inside a git repository"
    exit 1
fi

REPO="$(basename "$(git rev-parse --show-toplevel)")"

mkdir -p "$STATE_DIR"

MODE_FILE="$STATE_DIR/${REPO}.mode"

# ---------------- EXISTING MODE VALIDATION ----------------
if [[ -f "$MODE_FILE" ]]; then
    OLD_MODE=$(<"$MODE_FILE")
    case "$OLD_MODE" in
        SAFE|NORMAL|OPEN) ;;
        *)
            warn " Invalid existing mode in $MODE_FILE → resetting to SAFE"
            echo "SAFE" > "$MODE_FILE"
            ;;
    esac
fi

# ---------------- SET NEW MODE ----------------
echo "$MODE" > "$MODE_FILE"
info " Repository '$REPO' mode set to $MODE"

# ---------------- OPTIONAL: DISPLAY CURRENT MODE ----------------
info " Current mode file: $MODE_FILE"
cat "$MODE_FILE"