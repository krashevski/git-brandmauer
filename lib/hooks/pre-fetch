#!/usr/bin/env bash
# =============================================================
# Pre-hook for push/fetch/rebase — Brandmauer v1.0
# Blocks commands if repo is in SAFE/NORMAL mode
# =============================================================

set -euo pipefail

PREFIX="/usr/local"
LIB_DIR="$PREFIX/lib/brandmauer"
COMMON="$LIB_DIR/git/common.sh"
LOG_DIR="$HOME/.local/share/brandmauer/logs"
LOG_FILE="$LOG_DIR/security.log"

HOOKNAME="fetch"

mkdir -p "$LOG_DIR"

source "$COMMON"

# --- Repo ---
REPO=$(basename "$(git rev-parse --show-toplevel 2>/dev/null || echo 'unknown-repo')")

# --- Mode ---
MODE=$(get_git_mode)

# --- Logging and policy enforcement ---
timestamp() { date '+%F %T'; }

if [[ "$MODE" == "SAFE" || "$MODE" == "NORMAL" ]]; then
    echo "[$(timestamp)] [$REPO] git $HOOKNAME blocked in $MODE mode" >> "$LOG_FILE"
    echo "[SECURITY] [$REPO] git $HOOKNAME is disabled in $MODE mode"
    exit 1
else
    echo "[$(timestamp)] [$REPO] git $HOOKNAME allowed in $MODE mode" >> "$LOG_FILE"
fi

exit 0