#!/usr/bin/env bash
# git-brandmauer-mode
# Git-Brandmauer 2.0 — hooks-only
# Переключение режима текущего репозитория

set -euo pipefail

STATE_DIR="$HOME/.git-security/state"

if [[ $# -ne 1 ]]; then
    echo "Usage: $0 <SAFE|NORMAL|OPEN>"
    exit 1
fi

MODE="$1"

case "$MODE" in
    SAFE|NORMAL|OPEN) ;;
    *)
        echo "[ERROR] Invalid mode: $MODE"
        exit 1
        ;;
esac

# Проверка что мы внутри git-репозитория
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "[ERROR] Not inside a git repository"
    exit 1
fi

REPO="$(basename "$(git rev-parse --show-toplevel)")"

mkdir -p "$STATE_DIR"

MODE_FILE="$STATE_DIR/${REPO}.mode"
echo "$MODE" > "$MODE_FILE"

echo "[INFO] $REPO mode set to $MODE"