#!/usr/bin/env bash
# =============================================================
# brandmauer-doctor — диагностика Brandmauer
# =============================================================

set -euo pipefail

# ---------------- PATHS ----------------
PREFIX="/usr/local"
SECURITY_ROOT="$HOME/.git-security"
STATE_DIR="$SECURITY_ROOT/state"
REPO_LIST_FILE="$SECURITY_ROOT/repos.list"
AUTO_FILE="$SECURITY_ROOT/automatic"
TIME_FILE="$SECURITY_ROOT/automatic.time"

LIB_DIR="$PREFIX/lib/brandmauer/git"
SHARE_DIR="$PREFIX/share/brandmauer"
SHAREDLIB_DIR="$SHARE_DIR/shared-lib"

# ---------------- SOURCE ----------------
source "$LIB_DIR/state.sh"        # get_repo_mode / set_repo_mode
source "$SHAREDLIB_DIR/logging.sh"

# ---------------- INIT ----------------
echo "[INFO]  Brandmauer core initialized."

mkdir -p "$STATE_DIR"
mkdir -p "$SHARE_DIR/hooks"
mkdir -p "$HOME/.local/share/brandmauer/logs"

echo "[INFO]  Directories created: $STATE_DIR, $SHARE_DIR, $SHARE_DIR/hooks, $HOME/.local/share/brandmauer/logs"
echo "[INFO]  Global mode file: $STATE_DIR/global_mode"
echo "----------------------------------------------------"
echo
echo "==============================="
echo "      Brandmauer Doctor"
echo "==============================="
echo

# ---------------- CHECK GIT ----------------
if command -v git >/dev/null 2>&1; then
    echo "[ OK ] Git installed"
else
    echo "[FAIL] Git not found"
fi

# ---------------- CHECK HOOKS ----------------
HOOKS_DIR="$PREFIX/share/brandmauer/hooks"
HOOKS=("pre-push" "pre-fetch" "pre-rebase" "brandmauer_hook.sh")

[[ -d "$HOOKS_DIR" ]] || echo "[FAIL] Hooks directory missing"

for hook in "${HOOKS[@]}"; do
    HOOK_PATH="$HOOKS_DIR/$hook"
    if [[ -f "$HOOK_PATH" && -x "$HOOK_PATH" ]]; then
        echo "[ OK ] $hook executable"
    else
        echo "[WARN] $hook missing or not executable"
    fi
done

# ---------------- CHECK DIRECTORIES ----------------
[[ -d "$SHAREDLIB_DIR" ]] && echo "[ OK ] shared-lib present" || echo "[FAIL] shared-lib missing"
[[ -d "$STATE_DIR" ]] && echo "[ OK ] state directory exists" || echo "[FAIL] state directory missing"
[[ -d "$HOME/.local/share/brandmauer/logs" ]] && echo "[ OK ] log directory exists" || echo "[FAIL] log directory missing"

# ---------------- CHECK AUTOMATIC SAFE ----------------
if [[ -f "$AUTO_FILE" ]]; then
    auto_status=$(cat "$AUTO_FILE")
    echo "[INFO] Automatic SAFE: $auto_status"
else
    echo "[INFO] Automatic SAFE: OFF"
fi

# ---------------- CHECK REPOSITORIES ----------------
echo
echo "Repositories status:"

if [[ -f "$REPO_LIST_FILE" ]]; then
    while IFS= read -r repo_path || [[ -n "$repo_path" ]]; do
        [[ -z "$repo_path" ]] && continue
        [[ -d "$repo_path/.git" ]] || { echo "[WARN] $repo_path is not a Git repo"; continue; }

        repo_name=$(basename "$repo_path")
        mode=$(get_repo_mode "$repo_name")
        echo "[ OK ] $repo_name (mode: $mode)"
    done < "$REPO_LIST_FILE"
else
    echo "[WARN] Repository list not found"
fi

echo
echo "==============================="
echo "       Doctor complete"
echo "==============================="